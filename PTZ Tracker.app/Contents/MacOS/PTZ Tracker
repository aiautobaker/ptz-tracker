#!/bin/bash
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/../../.." >/dev/null 2>&1 && pwd )"
cd "$DIR"

if [ ! -d "venv" ]; then
    osascript -e 'display alert "Virtual environment not found! Please run PTZ Tracker.command first, or manually create the venv."'
    exit 1
fi

exec "$DIR/venv/bin/python3" tracker.py
